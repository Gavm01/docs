              "agency-setup/adding-clients",
              "agency-setup/white-label",
              "agency-setup/billing"
            ]
          },
          {
            "group": "Voice Calls",
            "pages": [
              "voice-calls/overview",
              "voice-calls/setting-up-voice",
              "voice-calls/call-handling",
              "voice-calls/voicemail"
            ]
          },
          {
            "group": "Inbox Channels",
            "pages": [
              "inbox-channels/overview",
              "inbox-channels/ghl",
              "inbox-channels/whatsapp",
              "inbox-channels/instagram",
              "inbox-channels/sms"
            ]
          },
          {
            "group": "Outbound Campaigns",
            "pages": [
              "outbound/overview",
              "outbound/campaigns",
              "outbound/templates",
              "outbound/compliance"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/conversations",
